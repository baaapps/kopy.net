<script>
const PROXY_URL = 'https://kopy-proxy.aseydah.workers.dev';
let mode = 'chat';
let history = [];
let uploadedFile = null;

function setMode(m) {
  mode = m;
  document.getElementById('btn-chat').classList.toggle('active', m === 'chat');
  document.getElementById('btn-image').classList.toggle('active', m === 'image');
  const input = document.getElementById('userInput');
  const hint = document.getElementById('hint');
  if (m === 'chat') {
    input.placeholder = 'Bir şeyler sorun...';
    hint.textContent = 'kopy.net • Sohbet modu • Enter ile gönder';
  } else {
    input.placeholder = 'Görseli tarif edin...';
    hint.textContent = 'kopy.net • Görsel modu • Detaylı tarif daha iyi sonuç verir';
  }
}

