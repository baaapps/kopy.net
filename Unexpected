      <span class="sug" onclick="suggest('Yapay zeka nasıl çalışır?')">YZ nasıl çalışır?</span>
      <span class="sug" onclick="suggest('İstanbul için 3 günlük gezi planı yap')">İstanbul gezisi</span>
      <span class="sug" onclick="setModeAndSuggest('image','sunset over Istanbul skyline, digital art')">🎨 Görsel üret</span>
    </div>`;
  msgs.appendChild(welcome);
  document.getElementById('closeBtn').classList.remove('visible');
}

function suggest(text) {
  document.getElementById('userInput').value = text;
  send();
}

function setModeAndSuggest(m, text) {
  setMode(m);
  document.getElementById('userInput').value = text;
  send();
}

function handleFile(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = (e) => {
    const base64 = e.target.result.split(',')[1];
    uploadedFile = { base64, mediaType: file.type || 'image/jpeg', name: file.name };
    const preview = document.getElementById('filePreview');
    const previewImg = document.getElementById('previewImg');
    document.getElementById('fileName').textContent = file.name;
    preview.style.display = 'flex';
    if (file.type.startsWith('image/')) {
      previewImg.src = e.target.result;
      previewImg.style.display = 'block';
    }
  };
  reader.readAsDataURL(file);
}

function removeFile() {
  uploadedFile = null;
  document.getElementById('filePreview').style.display = 'none';
  document.getElementById('fileInput').value = '';
}

function removeWelcome() {
  const w = document.getElementById('welcome');
  if (w) {
    w.remove();
    document.getElementById('closeBtn').classList.add('visible');
  }
}

function renderMarkdown(text) {
  return text
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
    .replace(/### (.+)/g, '<strong style="font-size:14px;display:block;margin:8px 0 3px">$1</strong>')
    .replace(/## (.+)/g, '<strong style="font-size:15px;display:block;margin:10px 0 4px">$1</strong>')
    .replace(/# (.+)/g, '<strong style="font-size:16px;display:block;margin:10px 0 5px">$1</strong>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/\n/g, '<br>');
}

function addMsg(text, role) {
  removeWelcome();
  const wrap = document.createElement('div');
  wrap.className = 'msg ' + role;
  const av = document.createElement('div');
  av.className = 'avatar ' + (role === 'ai' ? 'ai-av' : 'user-av');
  av.textContent = role === 'ai' ? 'K' : 'Sen';
  const b = document.createElement('div');
  b.className = 'bubble ' + (role === 'ai' ? 'ai-bubble' : 'user-bubble');
  if (role === 'ai') {
    b.innerHTML = renderMarkdown(text);
  } else {
    b.textContent = text;
  }
  wrap.appendChild(av);
  wrap.appendChild(b);
  document.getElementById('messages').appendChild(wrap);
  scroll();
}

function addImageMsg(prompt, imgUrl) {
  removeWelcome();
  const wrap = document.createElement('div');
  wrap.className = 'msg ai';
  const av = document.createElement('div');
  av.className = 'avatar ai-av'; av.textContent = 'K';
  const box = document.createElement('div');
  box.className = 'img-bubble';
  const img = document.createElement('img');
  img.src = imgUrl; img.alt = prompt;
  img.onerror = () => { box.innerHTML = '<div style="padding:14px;color:#f09595;font-size:13px">Görsel yüklenemedi, tekrar deneyin.</div>'; };
  const cap = document.createElement('div');
  cap.className = 'img-caption';
  cap.textContent = '🎨 ' + prompt;
  box.appendChild(img); box.appendChild(cap);
  wrap.appendChild(av); wrap.appendChild(box);
  document.getElementById('messages').appendChild(wrap);
  scroll();
}

function showTyping(isImage) {
  removeWelcome();
  const wrap = document.createElement('div');
  wrap.className = 'msg ai'; wrap.id = 'typing';
  const av = document.createElement('div');
  av.className = 'avatar ai-av'; av.textContent = 'K';
  const b = document.createElement('div');
  b.className = 'bubble ai-bubble';
  if (isImage) {
    b.style.cssText = 'font-size:13px;color:#9ca3af';
    b.textContent = '🎨 Görsel oluşturuluyor...';
  } else {
    b.classList.add('typing');
    b.innerHTML = '<div class="dot"></div><div class="dot"></div><div class="dot"></div>';
  }
  wrap.appendChild(av); wrap.appendChild(b);
  document.getElementById('messages').appendChild(wrap);
  scroll();
}

function removeTyping() {
  const t = document.getElementById('typing');
  if (t) t.remove();
}

function scroll() {
  const m = document.getElementById('messages');
  setTimeout(() => { m.scrollTop = m.scrollHeight; }, 50);
}

async function send() {
  const input = document.getElementById('userInput');
  const text = input.value.trim();
  if (!text && !uploadedFile) return;
  input.value = '';
  input.style.height = 'auto';
  document.getElementById('sendBtn').disabled = true;
  addMsg(text || '📎 ' + (uploadedFile ? uploadedFile.name : ''), 'user');
  if (mode === 'image') {
    await sendImage(text);
  } else {
    await sendChat(text);
  }
  document.getElementById('sendBtn').disabled = false;
  input.focus();
}

async function sendChat(text) {
  let content;
  if (uploadedFile) {
    if (uploadedFile.mediaType.startsWith('image/')) {
      content = [
        { type: 'image', source: { type: 'base64', media_type: uploadedFile.mediaType, data: uploadedFile.base64 } },
        { type: 'text', text: text || 'Bu görseli analiz et ve Türkçe açıkla.' }
      ];
    } else {
      content = [
        { type: 'document', source: { type: 'base64', media_type: 'application/pdf', data: uploadedFile.base64 } },
        { type: 'text', text: text || 'Bu belgeyi Türkçe özetle.' }
      ];
    }
    uploadedFile = null;
    removeFile();
  } else {
    content = text;
  }
  history.push({ role: 'user', content });
  showTyping(false);
  try {
    const res = await fetch(PROXY_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-haiku-4-5-20251001',
        max_tokens: 1000,
        system: 'Sen kopy.net sitesinin yapay zeka asistanısın. Türkçe konuşan kullanıcılara yardım ediyorsun. Cevaplarını Türkçe ver, samimi ve yardımsever ol. Bilgi kesim tarihin 2025 başıdır. Kesinlikle markdown kullanma, ** işareti kullanma, ## işareti kullanma. Sadece düz Türkçe cümle yaz. Tıbbi belgeler, kan tahlilleri ve sağlık dokümanlarını analiz edebilirsin, genel bilgi amaçlı yorum yap.',
        messages: history
      })
    });
    const data = await res.json();
    const reply = data.content ? data.content.map(c => c.text || '').join('') : 'Üzgünüm, bir hata oluştu.';
    removeTyping();
    addMsg(reply, 'ai');
    history.push({ role: 'assistant', content: reply });
  } catch(e) {
    removeTyping();
    addMsg('Bağlantı hatası, lütfen tekrar deneyin.', 'ai');
  }
}

async function sendImage(prompt) {
  showTyping(true);
  try {
    const res = await fetch(PROXY_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-haiku-4-5-20251001',
        max_tokens: 200,
        messages: [{ role: 'user', content: 'Translate this image prompt to English for an AI image generator. Reply ONLY with the translated prompt, nothing else: ' + prompt }]
      })
    });
    const data = await res.json();
    const englishPrompt = (data.content ? data.content[0].text : prompt).trim();
    const encoded = encodeURIComponent(englishPrompt + ', high quality, detailed, 4k');
    const seed = Math.floor(Math.random() * 99999);
    const imgUrl = 'https://image.pollinations.ai/prompt/' + encoded + '?width=768&height=512&seed=' + seed + '&nologo=true';
    removeTyping();
    addImageMsg(prompt, imgUrl);
  } catch(e) {
    removeTyping();
    addMsg('Görsel oluşturulamadı, tekrar deneyin.', 'ai');
  }
}

const ta = document.getElementById('userInput');
ta.addEventListener('input', () => {
  ta.style.height = 'auto';
  ta.style.height = Math.min(ta.scrollHeight, 100) + 'px';
});
ta.addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); }
});
window.visualViewport && window.visualViewport.addEventListener('resize', () => { scroll(); });
</script>
