<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>kopy.net — Yapay Zeka Asistanı</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --accent: #6c63ff;
  --accent2: #7c3aed;
  --border: #e5e7eb;
}
html { height: 100%; height: -webkit-fill-available; }
body {
  height: 100%; min-height: 100vh; min-height: -webkit-fill-available;
  background: #fff; color: #111;
  font-family: 'DM Sans', sans-serif;
  overflow: hidden;
  -webkit-font-smoothing: antialiased;
}

/* Sidebar */
.sidebar {
  position: fixed; top: 0; bottom: 0;
  width: calc((100vw - 860px) / 2);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 14px; padding: 20px 16px; z-index: 0; overflow: hidden;
}
.sidebar-left { left: 0; background: linear-gradient(90deg,#f0f4ff,#f8f9ff); border-right: 1px solid #e8eeff; }
.sidebar-right { right: 0; background: linear-gradient(270deg,#f0f4ff,#f8f9ff); border-left: 1px solid #e8eeff; }
.sidebar svg.circuit { position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0.35; }
.fcard { background: #fff; border: 1px solid #e8eeff; border-radius: 12px; padding: 11px 13px; width: 100%; box-shadow: 0 2px 8px rgba(108,99,255,0.06); position: relative; z-index: 1; }
.fcard-head { display: flex; align-items: center; gap: 7px; margin-bottom: 4px; }
.fcard-icon { width: 26px; height: 26px; border-radius: 7px; display: flex; align-items: center; justify-content: center; font-size: 13px; flex-shrink: 0; }
.fcard-title { font-size: 11px; font-weight: 600; color: #111; }
.fcard-body { font-size: 10px; color: #9ca3af; line-height: 1.4; }
.fbubble { background: #ede9fe; border-radius: 10px; border-top-left-radius: 3px; padding: 9px 11px; font-size: 10px; color: #5b21b6; line-height: 1.5; width: 100%; position: relative; z-index: 1; }
.fbubble-white { background: #fff; border: 1px solid #e8eeff; border-radius: 10px; border-top-right-radius: 3px; padding: 9px 11px; font-size: 10px; color: #374151; line-height: 1.5; width: 100%; position: relative; z-index: 1; }
.fstat { background: #fff; border: 1px solid #e8eeff; border-radius: 10px; padding: 8px 12px; text-align: center; width: 100%; position: relative; z-index: 1; }
.fstat-num { font-size: 18px; font-weight: 700; color: #6c63ff; }
.fstat-label { font-size: 9px; color: #9ca3af; }
.fimg { background: #fff; border: 1px solid #e8eeff; border-radius: 10px; overflow: hidden; width: 100%; position: relative; z-index: 1; }
.fimg-ph { height: 55px; background: linear-gradient(135deg,#ede9fe,#ddd6fe); display: flex; align-items: center; justify-content: center; font-size: 20px; }
.fimg-label { padding: 5px 10px; font-size: 9px; color: #9ca3af; }
@media(max-width: 1100px) { .sidebar { display: none; } }

/* Layout */
.layout {
  position: relative; z-index: 1;
  height: 100vh; height: 100dvh;
  display: flex; flex-direction: column;
  max-width: 860px; margin: 0 auto; padding: 0 16px;
}

/* Header */
header {
  display: flex; align-items: center; gap: 12px;
  padding: 14px 0 12px;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}
.logo {
  width: 38px; height: 38px; flex-shrink: 0;
  background: linear-gradient(135deg,var(--accent),#a78bfa);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 16px; color: #fff;
  cursor: pointer; transition: transform 0.15s;
}
.logo:hover { transform: scale(1.05); }
.site-name { font-size: 16px; font-weight: 600; color: #111; cursor: pointer; }
.tagline { font-size: 11px; color: #9ca3af; margin-top: 1px; }
.header-right { margin-left: auto; display: flex; gap: 6px; align-items: center; flex-shrink: 0; }
.mode-btn {
  background: #f3f4f6; border: 1px solid var(--border);
  color: #6b7280; font-size: 11px; font-family: 'DM Sans', sans-serif;
  padding: 5px 10px; border-radius: 20px; cursor: pointer; transition: all 0.2s; white-space: nowrap;
}
.mode-btn.active { background: #ede9fe; border-color: #c4b5fd; color: var(--accent2); }
.close-btn {
  background: #f3f4f6; border: 1px solid var(--border); color: #9ca3af;
  width: 30px; height: 30px; border-radius: 50%;
  display: none; align-items: center; justify-content: center;
  cursor: pointer; font-size: 14px; transition: all 0.2s; flex-shrink: 0;
}
.close-btn:hover { background: #fee2e2; border-color: #fca5a5; color: #ef4444; }
.close-btn.visible { display: flex; }

/* Messages */
.messages {
  flex: 1; overflow-y: auto; overflow-x: hidden;
  padding: 20px 0 8px;
  display: flex; flex-direction: column; gap: 16px;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: thin; scrollbar-color: #e5e7eb transparent;
  min-height: 0; background: #f9fafb;
}

/* Welcome */
.welcome {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  text-align: center; gap: 16px; padding: 40px 20px;
  background: #f9fafb;
}
.welcome-icon {
  width: 72px; height: 72px;
  background: #ede9fe; border: 1px solid #c4b5fd;
  border-radius: 20px;
  display: flex; align-items: center; justify-content: center;
  animation: float 3s ease-in-out infinite;
}
@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-5px)} }
.welcome h1 { font-size: 22px; font-weight: 500; color: #111; line-height: 1.4; }
.welcome p { font-size: 14px; color: #374151; font-weight: 500; max-width: 320px; line-height: 1.6; }
.suggestions { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-top: 4px; }
.sug {
  background: #ede9fe; border: 1px solid #c4b5fd;
  color: var(--accent2); font-size: 13px; font-weight: 600;
  padding: 7px 14px; border-radius: 20px; cursor: pointer; transition: all 0.2s;
}
.sug:hover { background: #ddd6fe; }

/* Messages */
.msg { display: flex; gap: 10px; align-items: flex-start; animation: fadeUp 0.25s ease; }
@keyframes fadeUp { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:translateY(0)} }
.msg.user { flex-direction: row-reverse; }
.avatar { width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 500; flex-shrink: 0; }
.ai-av { background: linear-gradient(135deg,var(--accent),#a78bfa); color: #fff; font-size: 13px; font-weight: 700; }
.user-av { background: #e5e7eb; border: 1px solid #d1d5db; color: #6b7280; }
.bubble { max-width: 78%; padding: 12px 16px; border-radius: 16px; font-size: 14px; line-height: 1.65; word-break: break-word; }
.ai-bubble { background: #fff; border: 1px solid var(--border); color: #111; border-top-left-radius: 4px; }
.user-bubble { background: linear-gradient(135deg,var(--accent),var(--accent2)); color: #fff; border-top-right-radius: 4px; }
.img-bubble { max-width: 78%; border-radius: 14px; overflow: hidden; border: 1px solid var(--border); background: #fff; }
.img-bubble img { width: 100%; display: block; }
.img-caption { padding: 8px 12px; font-size: 11px; color: #9ca3af; }
.typing { display: flex; gap: 5px; padding: 14px 16px; align-items: center; }
.dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); opacity: 0.4; animation: pulse 1.2s ease infinite; }
.dot:nth-child(2){animation-delay:.2s} .dot:nth-child(3){animation-delay:.4s}
@keyframes pulse{0%,100%{opacity:.3;transform:scale(1)}50%{opacity:1;transform:scale(1.3)}}

/* Input */
.input-area {
  flex-shrink: 0; padding: 12px 0;
  padding-bottom: max(16px, env(safe-area-inset-bottom));
  border-top: 1px solid var(--border);
}
.file-preview {
  display: flex; align-items: center; gap: 8px;
  background: #ede9fe; border: 1px solid #c4b5fd;
  border-radius: 10px; padding: 6px 10px; margin-bottom: 8px;
  font-size: 12px; color: var(--accent2);
}
.file-preview img { width: 36px; height: 36px; object-fit: cover; border-radius: 6px; }
.file-preview .rm { cursor: pointer; color: #9ca3af; margin-left: auto; }
.input-box {
  display: flex; gap: 8px; align-items: flex-end;
  background: #f9fafb; border: 1px solid var(--border);
  border-radius: 14px; padding: 8px 8px 8px 14px; transition: border-color 0.2s;
}
.input-box:focus-within { border-color: #a78bfa; }
.upload-btn {
  background: #f3f4f6; border: 1px solid var(--border); color: #9ca3af;
  width: 36px; height: 36px; border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; font-size: 16px; flex-shrink: 0; transition: all 0.2s;
}
.upload-btn:hover { background: #ede9fe; border-color: #c4b5fd; color: var(--accent2); }
#userInput {
  flex: 1; background: transparent; border: none; outline: none;
  color: #111; font-size: 15px; font-family: 'DM Sans', sans-serif;
  resize: none; min-height: 24px; max-height: 100px; line-height: 1.5;
  -webkit-appearance: none;
}
#userInput::placeholder { color: #9ca3af; }
#sendBtn {
  width: 36px; height: 36px; border-radius: 10px;
  background: linear-gradient(135deg,var(--accent),var(--accent2));
  border: none; color: #fff; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; font-size: 15px; -webkit-appearance: none;
}
#sendBtn:active { opacity: 0.8; }
#sendBtn:disabled { opacity: 0.35; }
.input-hint { text-align: center; margin-top: 8px; font-size: 10px; color: #9ca3af; }

@media(max-width: 500px) {
  .tagline { display: none; }
  .bubble { max-width: 86%; }
  .welcome h1 { font-size: 18px; }
  .input-hint { display: none; }
}
</style>
</head>
